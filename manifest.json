{
  "manifest_version": 3,
  "name": "disenshittify",
  "version": "0.1.0",
  "description": "Removes enshittification features from platforms. YouTube, X/Twitter, and LinkedIn.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "disenshittify",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": ["storage"],
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["platforms/youtube.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["platforms/twitter.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["platforms/linkedin.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "disenshittify@neverbot.com",
      "strict_min_version": "109.0"
    }
  }
}
